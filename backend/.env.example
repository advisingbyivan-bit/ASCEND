# Server
PORT=3000
NODE_ENV=development

# Database (Railway auto-provides DATABASE_URL when you add a PostgreSQL plugin)
DATABASE_URL=postgresql://ascend:ascend_secret@localhost:5432/ascend

# Redis (Railway auto-provides REDIS_URL when you add a Redis plugin)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-long-random-string

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=ascend-scans

# Anthropic (Claude Vision for IRIS body scan analysis)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Google Sign-In
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Apple Sign-In
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
APPLE_SERVICE_ID=com.ascend.app
APPLE_PRIVATE_KEY_PATH=./AuthKey.p8
# For Railway: base64-encode your AuthKey.p8 -> cat AuthKey.p8 | base64
APPLE_PRIVATE_KEY_BASE64=

# APNs (Push Notifications)
APNS_KEY_PATH=./APNsAuthKey.p8
# For Railway: base64-encode your APNsAuthKey.p8 -> cat APNsAuthKey.p8 | base64
APNS_KEY_BASE64=
APNS_KEY_ID=XXXXXXXXXX
APNS_TEAM_ID=XXXXXXXXXX
APNS_BUNDLE_ID=com.ascend.app
APNS_PRODUCTION=false
