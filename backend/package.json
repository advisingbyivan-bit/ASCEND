{
  "name": "ascend-backend",
  "version": "1.0.0",
  "description": "ASCEND body transformation tracker API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "migrate": "node -e \"const fs=require('fs');const path=require('path');const {Pool}=require('pg');const ssl=process.env.NODE_ENV==='production'?{ssl:{rejectUnauthorized:false}}:{};const pool=new Pool({connectionString:process.env.DATABASE_URL,...ssl});const sql=fs.readFileSync(path.join(__dirname,'src/db/migrations/001_initial.sql'),'utf8');pool.query(sql).then(()=>{console.log('Migration complete');pool.end()}).catch(e=>{console.error(e);pool.end();process.exit(1)})\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "apple-signin-auth": "^1.7.6",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bull": "^4.10.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
